  </Settings>
  <Actions Context=\"Author\">
    <Exec>
      <Command>C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe</Command>
      <Arguments>-ExecutionPolicy Bypass -File \"C:\\Veritas_Lab\\gravity-omega-v2\\run_terafab_monitor.ps1\"</Arguments>
